# Supabase project settings. Never expose the secret key in frontend code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_replace_me
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Use 0 only for local HTTP development. Heroku sets X-Forwarded-Proto=https,
# so this can be omitted in production or explicitly set to 1.
PEAK_COOKIE_SECURE=0

# Optional: used only when backend/sync_exercises.py calls this app's HTTP API.
GYM_TRACKER_API_URL=http://127.0.0.1:8000/api

# Session and upload controls.
PEAK_REFRESH_COOKIE_SECONDS=2592000
ALLOW_REMOTE_FOOD_UPLOAD=0

# Exact product reads use the current API. Include a real contact address in
# the user agent before production so Open Food Facts can identify your app.
OPENFOODFACTS_PRODUCT_API_VERSION=v3
OPENFOODFACTS_USER_AGENT="PeakWorkoutApp/1.0 (contact: you@example.com)"

# Google Gemini server-side credentials and Interactions API model.
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
# Free-tier Interactions API retention. Change to 55 only if using a paid tier.
GEMINI_INTERACTION_RETENTION_DAYS=1
